# Copy this file to ".env" and fill in your values.

# Your OpenAI API key (or any OpenAI-compatible provider key)
OPENAI_API_KEY=sk-...

# Vision-capable model. Defaults to gpt-4o-mini if not set.
OPENAI_MODEL=gpt-4o-mini

# Optional: custom base URL for OpenAI-compatible providers
# (e.g. Azure, OpenRouter, local servers). Leave blank for OpenAI.
OPENAI_BASE_URL=

# Optional: default AI provider.
# One of: openai | anthropic | gemini | openrouter | custom
AI_PROVIDER=openai

# Keys for other providers (used when you select them in Settings):
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=
